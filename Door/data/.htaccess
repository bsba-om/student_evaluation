<IfModule mod_php7.c>
  php_value output_buffering Off
  php_value default_charset "UTF-8"
</IfModule>
<IfModule mod_php8.c>
  php_value output_buffering Off
  php_value default_charset "UTF-8"
</IfModule>
<IfModule mod_rewrite.c>
  RewriteEngine On
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>
